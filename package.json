{
  "name": "face-locator-enrollment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "portless run next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:web": "eslint app components lib tests middleware.ts",
    "lint:markdown": "markdownlint-cli2",
    "lint:desktop": "pnpm --filter macos-uploader lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:web": "pnpm test",
    "test:desktop": "pnpm --filter macos-uploader test",
    "test:e2e": "playwright test",
    "typecheck:web": "tsc --noEmit",
    "typecheck:desktop": "pnpm --filter macos-uploader typecheck",
    "verify:precommit": "pnpm lint:web && pnpm lint:markdown && pnpm test:web && pnpm lint:desktop && pnpm test:desktop",
    "verify:prepush": "pnpm typecheck:web && pnpm lint:web && pnpm test:coverage && pnpm build && pnpm typecheck:desktop && pnpm desktop:build",
    "desktop:dev": "pnpm --filter macos-uploader dev",
    "desktop:build": "pnpm --filter macos-uploader build",
    "desktop:tauri": "pnpm --filter macos-uploader tauri build",
    "arch:generate": "structurizr-site-generatr --workspace architecture.structurizr --output docs/architecture-site",
    "arch:serve": "cd docs/architecture-site && npx http-server -p 8080"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "next": "15.5.15",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@aws-sdk/client-rekognition": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.15",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "markdownlint-cli2": "^0.22.1",
    "portless": "^0.10.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
