aws_region   = "eu-west-1"
environment  = "poc"
project_name = "face-locator"
database_name = "face_locator"
database_username = "face_locator_app"
database_allowed_cidr_blocks = []
selfie_retention_days = 30
unmatched_event_photo_retention_days = 2
matched_event_photo_retention_days = 30
temporary_artifact_retention_days = 1
cloudwatch_log_retention_days = 14
search_faces_on_event_photo_upload = false
matched_photo_notifier_schedule_expression = "rate(12 hours)"
match_link_ttl_days = 30
ses_from_email = "noreply@example.com"
